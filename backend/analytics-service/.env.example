# backend/analytics-service/.env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
PORT=4003

# --- MongoDB ---
# Separate database from auth-service and issue-service.
MONGO_URI=mongodb://localhost:27017/civicase-analytics

# --- JWT ---
# Must match JWT_SECRET in auth-service exactly.
# This service only verifies tokens; it never issues them.
JWT_SECRET=replace_with_a_long_random_secret

# --- Gemini AI ---
# Obtain from https://ai.google.dev/
# LangChain @langchain/google-genai reads GOOGLE_API_KEY; the official SDK accepts GEMINI_API_KEY.
# Set both to the same key, or at least one.
GEMINI_API_KEY=replace_with_your_gemini_api_key
GOOGLE_API_KEY=replace_with_your_gemini_api_key
