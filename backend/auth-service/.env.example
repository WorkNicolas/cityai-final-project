# backend/auth-service/.env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
PORT=4001

# --- MongoDB ---
# Connection string for the auth-service database.
# Each service uses its own database to maintain domain isolation.
MONGO_URI=mongodb://localhost:27017/cityai-auth

# --- JWT ---
# Must match JWT_SECRET in issue-service and analytics-service
# so all services can verify tokens issued by auth-service.
JWT_SECRET=e9a25b7e440fbd69bce4d5cb4956c4fa927655d13372e1a4d58306209fc717f24b7550406476ea68fc94fdeae46cc04e7a501f7821c675bd089eff46bf8b9caf
JWT_EXPIRES_IN=7d

# --- Cookie ---
# Set to 'true' in production (requires HTTPS).
COOKIE_SECURE=false
