# backend/auth-service/.env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
PORT=4001

# --- MongoDB ---
# Connection string for the auth-service database.
# Each service uses its own database to maintain domain isolation.
MONGO_URI=mongodb://localhost:27017/cityai-auth

# --- JWT ---
# Must match JWT_SECRET in issue-service and analytics-service
# so all services can verify tokens issued by auth-service.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Cookie ---
# Set to 'true' in production (requires HTTPS).
COOKIE_SECURE=false

# --- Frontend ---
# URL for redirection after OAuth logins.
FRONTEND_URL=http://localhost:3000

# --- OAuth (Passport) ---
# Obtain these credentials by creating OAuth apps in Google Cloud and GitHub Developer Settings.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
