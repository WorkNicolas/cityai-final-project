# backend/issue-service/.env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
PORT=4002

# --- MongoDB ---
# Separate database from auth-service — domain isolation is required.
MONGO_URI=mongodb://localhost:27017/cityai-issues

# --- JWT ---
# Must match JWT_SECRET in auth-service exactly.
# This service only verifies tokens; it never issues them.
JWT_SECRET=replace_with_a_long_random_secret

# --- Inter-service communication ---
# The URL of the Analytics Service GraphQL endpoint.
ANALYTICS_SERVICE_GRAPHQL_URL=http://localhost:4003/graphql
# Shared secret for internal service-to-service requests.
INTERNAL_SERVICE_TOKEN=dev-internal-service-token
